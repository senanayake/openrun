# Database
POSTGRES_DB=openrun
POSTGRES_USER=openrun
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://openrun:changeme@postgres:5432/openrun

# Redis
REDIS_URL=redis://redis:6379

# API
API_SECRET_KEY=change-this-to-a-random-secret
API_PORT=8000

# Next.js web app
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Ollama (local LLM for coaching narrative generation — optional)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3

# Strava integration (optional)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:3000/api/auth/strava/callback

# Garmin Connect integration (optional)
GARMIN_EMAIL=
GARMIN_PASSWORD=
